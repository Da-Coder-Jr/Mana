#!/usr/bin/env bash
set -euo pipefail

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
MANA_HOME="$CONFIG_HOME/mana-terminal"
WARP_THEME_HOME="$HOME/.warp/themes"

print_help() {
  cat <<'HELP'
Usage: mana-term <command>

Commands:
  doctor       Show which optional tools are installed
  themes       List installed Warp themes
  paths        Print config and theme install locations
  help         Show this message
HELP
}

cmd_doctor() {
  local tool
  for tool in starship fzf zoxide eza bat git; do
    if command -v "$tool" >/dev/null 2>&1; then
      printf '✓ %s -> %s\n' "$tool" "$(command -v "$tool")"
    else
      printf '• %s -> not installed\n' "$tool"
    fi
  done
}

cmd_themes() {
  local theme_path

  if [ -d "$WARP_THEME_HOME" ]; then
    find "$WARP_THEME_HOME" -maxdepth 1 -type f -name 'mana-*.yaml' | sort | while IFS= read -r theme_path; do
      basename "$theme_path"
    done
  fi
}

cmd_paths() {
  printf 'config: %s\n' "$MANA_HOME"
  printf 'warp themes: %s\n' "$WARP_THEME_HOME"
}

command_name="${1:-help}"
case "$command_name" in
  doctor)
    cmd_doctor
    ;;
  themes)
    cmd_themes
    ;;
  paths)
    cmd_paths
    ;;
  help|-h|--help)
    print_help
    ;;
  *)
    printf 'Unknown command: %s\n\n' "$command_name" >&2
    print_help >&2
    exit 1
    ;;
esac
